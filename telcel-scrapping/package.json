{
  "name": "telcel-data-monitor",
  "version": "1.0.0",
  "description": "Automated Tel Cel data usage monitor with daily email reports",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:local": "ts-node src/index.ts",
    "deploy": "npm run build && gcloud functions deploy checkTelcelUsage --runtime nodejs20 --trigger-http --allow-unauthenticated --memory 1GB --timeout 540s --source . --entry-point checkTelcelUsage",
    "clean": "rm -rf dist node_modules package-lock.json"
  },
  "keywords": [
    "playwright",
    "telcel",
    "data-usage",
    "automation",
    "gcp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/functions-framework": "^3.5.1",
    "@google-cloud/secret-manager": "^5.2.0",
    "dotenv": "^16.4.7",
    "nodemailer": "^8.0.1",
    "pino": "^9.4.0",
    "pino-pretty": "^9.2.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.16",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engine": {
    "node": ">=20.0.0"
  }
}
